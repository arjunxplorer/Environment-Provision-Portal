{
  "dashboard": {
    "id": null,
    "uid": "env-{{ .Name }}",
    "title": "Environment: {{ .Name }}",
    "tags": ["environment", "portal", "{{ .Name }}"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "namespace",
          "type": "constant",
          "current": {
            "value": "env-{{ .Name }}"
          },
          "label": "Namespace"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Pod CPU Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"env-{{ .Name }}\", container!=\"\"}[5m])) by (pod)",
            "legendFormat": "{{ .pod }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Pod Memory Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"env-{{ .Name }}\", container!=\"\"}) by (pod)",
            "legendFormat": "{{ .pod }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Pod Count",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "count(kube_pod_info{namespace=\"env-{{ .Name }}"})"
          }
        ]
      },
      {
        "id": 4,
        "title": "Network I/O",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "sum(rate(container_network_receive_bytes_total{namespace=\"env-{{ .Name }}"}[5m])) by (pod)",
            "legendFormat": "rx: {{ .pod }}"
          },
          {
            "expr": "sum(rate(container_network_transmit_bytes_total{namespace=\"env-{{ .Name }}"}[5m])) by (pod)",
            "legendFormat": "tx: {{ .pod }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          }
        }
      },
      {
        "id": 5,
        "title": "Resource Quota Usage",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "kube_resourcequota{namespace=\"env-{{ .Name }}\", type=\"used\", resource=\"requests.cpu\"} / kube_resourcequota{namespace=\"env-{{ .Name }}\", type=\"hard\", resource=\"requests.cpu\"}",
            "legendFormat": "CPU"
          },
          {
            "expr": "kube_resourcequota{namespace=\"env-{{ .Name }}\", type=\"used\", resource=\"requests.memory\"} / kube_resourcequota{namespace=\"env-{{ .Name }}\", type=\"hard\", resource=\"requests.memory\"}",
            "legendFormat": "Memory"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "thresholds": {
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 0.7, "color": "yellow" },
                { "value": 0.9, "color": "red" }
              ]
            }
          }
        }
      }
    ]
  },
  "folderId": 0,
  "overwrite": true
}
